1 VERSIONINFO
 FILEVERSION    @MUSE_APP_VERSION_MAJOR@,@MUSE_APP_VERSION_MINOR@,@MUSE_APP_VERSION_PATCH@,0
 PRODUCTVERSION @MUSE_APP_VERSION_MAJOR@,@MUSE_APP_VERSION_MINOR@,@MUSE_APP_VERSION_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x40004L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "MuseCY Holdings Ltd"
            VALUE "FileDescription",  "@MUSE_APP_TITLE_VERSION@"
            VALUE "FileVersion",      "@MUSE_APP_VERSION@"
            VALUE "InternalName",     "@MUSE_APP_NAME@@MUSE_APP_VERSION_MAJOR@"
            VALUE "LegalCopyright",   "Copyright (C) 1999-2026 Audacity and others. Published under the GNU General Public License version 3."
            VALUE "OriginalFilename", "@MUSE_APP_NAME@@MUSE_APP_VERSION_MAJOR@.exe"
            VALUE "ProductName",      "@MUSE_APP_TITLE_VERSION@"
            VALUE "ProductVersion",   "@MUSE_APP_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
