<?xml version="1.0" encoding="UTF-8"?>

<?include "cpack_variables.wxi"?>

<?define ProdName="$(var.MUSE_APP_TITLE_VERSION)"?>
<?define ShortProdName="$(var.MUSE_APP_TITLE) $(var.CPACK_PACKAGE_VERSION_MAJOR) $(var.MUSE_APP_RELEASE_CHANNEL)"?>
<?define ExeKey="$(var.ShortProdName).exe"?>
<?define ExeName="$(var.MUSE_EXECUTABLE_NAME).exe"?>
<?define RegistryRoot="HKMU"?> <!--HKCU / HKLM-->

<?define ExePath="[INSTALL_ROOT]bin\$(var.ExeName)"?>
<?define ExeIcon="$(var.ExePath),0"?>
<?define DocIcon="$(var.ExePath),1"?>

<?include "audacity_file_types.wxi"?>

<?if "$(var.MUSE_APP_RELEASE_CHANNEL)" != ""?>
<?define ProgIdSuffix="$(var.CPACK_PACKAGE_VERSION_MAJOR).$(var.MUSE_APP_RELEASE_CHANNEL)"?>
<?else?>
<?define ProgIdSuffix="$(var.CPACK_PACKAGE_VERSION_MAJOR)"?>
<?endif?>

<!-- Primary (project) and the media "open with" helper. -->
<?define Aup4ProgId="Audacity.aup4.$(var.ProgIdSuffix)"?>
<?define MediaProgId="Audacity.Media.$(var.ProgIdSuffix)"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi" RequiredVersion="3.6.3303.0">

    <Product Id="$(var.CPACK_WIX_PRODUCT_GUID)"
        Name="$(var.ProdName)"
        Language="1033"
        Version="$(var.CPACK_PACKAGE_VERSION)"
        Manufacturer="$(var.CPACK_PACKAGE_VENDOR)"
        UpgradeCode="$(var.CPACK_WIX_UPGRADE_GUID)">

        <Package InstallerVersion="301" Compressed="yes" />

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" CompressionLevel="high" />

        <MajorUpgrade
            AllowSameVersionUpgrades="yes"
            DowngradeErrorMessage="A later version of [ProductName] is already installed. Setup will now exit." />

        <WixVariable Id="WixUILicenseRtf" Value="$(var.CPACK_WIX_LICENSE_RTF)" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALL_ROOT" />

        <!-- See https://docs.microsoft.com/ru-ru/windows/win32/msi/reinstallmode that explains different modes -->
        <Property Id='REINSTALLMODE' Value='dmus' />

        <?ifdef CPACK_WIX_PRODUCT_ICON?>
        <Property Id="ARPPRODUCTICON">ProductIcon.ico</Property>
        <Icon Id="ProductIcon.ico" SourceFile="$(var.CPACK_WIX_PRODUCT_ICON)" />
        <?endif?>

        <?ifdef CPACK_WIX_UI_BANNER?>
        <WixVariable Id="WixUIBannerBmp" Value="$(var.CPACK_WIX_UI_BANNER)" />
        <?endif?>

        <?ifdef CPACK_WIX_UI_DIALOG?>
        <WixVariable Id="WixUIDialogBmp" Value="$(var.CPACK_WIX_UI_DIALOG)" />
        <?endif?>

        <Property Id='ARPHELPLINK'>https://audacityteam.org</Property>
        <Property Id='ARPURLINFOABOUT'>https://audacityteam.org</Property>
        <!-- Properties from CMake -->
        <?include "properties.wxi"?>

        <!-- Add to checkbox to launch program after install ²-->
        <UI>
            <UIRef Id='WixUI_InstallDir' />
            <Publish Dialog="ExitDialog"
                Control="Finish"
                Event="DoAction"
                Value="LaunchApplication">WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed</Publish>
        </UI>
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch $(var.ProdName)" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
        <Property Id="WixShellExecTarget" Value="[#CM_FP_bin.$(var.ExeName)]" />
        <CustomAction Id="LaunchApplication" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" />

        <Component Id="RegisterTypes" Directory="TARGETDIR" Guid="*">
            <!-- In order to work with Default Programs -->
            <?define CapabilitiesKey="SOFTWARE\$(var.ShortProdName)\Capabilities"?>
            <RegistryKey Root="$(var.RegistryRoot)" Key="$(var.CapabilitiesKey)">
                <!-- Application info -->
                <RegistryValue Name="ApplicationDescription" Value="$(var.ProdName)" Type="string" KeyPath="yes" />
                <RegistryValue Name="ApplicationIcon" Value="$(var.ExeIcon)" Type="string" />
                <RegistryValue Name="ApplicationName" Value="$(var.ProdName)" Type="string" />
                <RegistryValue Key="DefaultIcon" Value="$(var.DocIcon)" Type="string" />

                <!-- File associations -->
                <RegistryKey Key="FileAssociations">
                    <RegistryValue Name=".aup4" Value="$(var.Aup4ProgId)" Type="string" />
                    <!-- TODO: Add other file types here too? -->
                </RegistryKey>

                <!-- MIME associations -->
                <RegistryKey Key="MIMEAssociations">
                    <RegistryValue Name="application/x-audacity" Value="$(var.Aup4ProgId)" Type="string" />
                </RegistryKey>
            </RegistryKey>

            <!-- Do a full cleanup on uninstall -->
            <RemoveRegistryKey Id="RemoveAppCapabilitiesTree"
                Root="$(var.RegistryRoot)"
                Key="SOFTWARE\$(var.ShortProdName)"
                Action="removeOnUninstall" />

            <RegistryValue Root="$(var.RegistryRoot)" Key="SOFTWARE\RegisteredApplications" Name="$(var.ProdName)" Value="$(var.CapabilitiesKey)" Type="string" />

            <!-- App Paths to support Start,Run -> "myapp" -->
            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\$(var.ExeKey)" ForceDeleteOnUninstall="yes">
                <RegistryValue Value="$(var.ExePath)" Type="string" />
                <RegistryValue Name="Path" Value="[INSTALL_ROOT]bin" Type="string" />
            </RegistryKey>

            <!-- Extend to the "open with" list + Win7 jump menu pinning  -->
            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\Applications\$(var.ExeKey)" ForceDeleteOnUninstall="yes">
                <RegistryKey Key="SupportedTypes">
                    <RegistryValue Name=".aup4" Value="" Type="string" />
                    <?foreach EXT in $(var.AudacitySecondaryExts)?>
                    <RegistryValue Name=".$(var.EXT)" Value="" Type="string" />
                    <?endforeach?>
                </RegistryKey>

                <RegistryValue Name="FriendlyAppName" Value="$(var.ProdName)" Type="string" />
                <RegistryValue Key="shell\open" Name="FriendlyAppName" Value="$(var.ProdName)" Type="string" />
                <RegistryValue Key="shell\open\command" Value="&quot;$(var.ExePath)&quot; &quot;%1&quot;" Type="string" />
            </RegistryKey>

            <!-- Add friendly name to be shown in "Open with" menu -->
            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\Applications\$(var.ExeName)" ForceDeleteOnUninstall="yes">
                <RegistryValue Name="FriendlyAppName" Value="$(var.ProdName)" Type="string" />
                <RegistryValue Key="DefaultIcon" Value="$(var.ExeIcon)" Type="string" />
                <RegistryValue Key="shell\open" Name="FriendlyAppName" Value="$(var.ProdName)" Type="string" />
                <RegistryValue Key="shell\open\command" Value="&quot;$(var.ExePath)&quot; &quot;%1&quot;" Type="string" />
            </RegistryKey>

            <!-- Add main project file type association -->
            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\$(var.Aup4ProgId)" ForceDeleteOnUninstall="yes">
                <RegistryValue Value="Audacity File" Type="string" />
                <RegistryValue Key="DefaultIcon" Value="$(var.DocIcon)" Type="string" />
                <RegistryValue Key="shell\open\command" Value="&quot;$(var.ExePath)&quot; &quot;%1&quot;" Type="string" />
            </RegistryKey>
            <RegistryValue Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\Audacity.aup4\CurVer" Value="$(var.Aup4ProgId)" Type="string" />

            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\.aup4">
                <RegistryValue Value="$(var.Aup4ProgId)" Type="string" />
                <RegistryValue Name="Content Type" Value="application/x-audacity" Type="string" />
            </RegistryKey>

            <!-- Add importable file types association -->
            <RegistryKey Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\$(var.MediaProgId)" ForceDeleteOnUninstall="yes">
                <RegistryValue Value="Audacity audio file" Type="string" />
                <RegistryValue Key="DefaultIcon" Value="$(var.ExeIcon)" Type="string" />
                <RegistryValue Key="shell\open\command" Value="&quot;$(var.ExePath)&quot; &quot;%1&quot;" Type="string" />
            </RegistryKey>

            <?foreach EXT in $(var.AudacitySecondaryExts)?>
            <RegistryValue Root="$(var.RegistryRoot)" Key="SOFTWARE\Classes\.$(var.EXT)\OpenWithProgids" Name="$(var.MediaProgId)" Value="" Type="string" />
            <?endforeach?>
        </Component>

        <!-- Add program shortcuts to the start menu and desktop -->
        <DirectoryRef Id="TARGETDIR">
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="$(var.ProdName)" />
            </Directory>
            <Directory Id="DesktopFolder" Name="Desktop" />
        </DirectoryRef>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcuts" Guid="*">
                <Shortcut Id="StartMenuAppShortcut"
                    Name="$(var.ProdName)"
                    Description="$(var.ProdName)"
                    Target="$(var.ExePath)"
                    WorkingDirectory="CM_DP_bin" />
                <Shortcut Id="UninstallShortcut"
                    Name="Uninstall $(var.ProdName)"
                    Description="Uninstall $(var.ProdName)"
                    Target="[SystemFolder]msiexec.exe"
                    Arguments="/x [ProductCode]" />
                <RemoveFolder Id="RemoveApplicationProgramsFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall" />
                <RegistryValue Root="HKCU"
                    Key="SOFTWARE\$(var.ShortProdName)\Shortcuts"
                    Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <DirectoryRef Id="DesktopFolder">
            <Component Id="ApplicationDesktopShortcut" Guid="*">
                <Shortcut Id="DesktopAppShortcut"
                    Name="$(var.ProdName)"
                    Description="$(var.ProdName)"
                    Target="$(var.ExePath)"
                    WorkingDirectory="CM_DP_bin" />
                <RegistryValue Root="HKCU"
                    Key="SOFTWARE\$(var.ShortProdName)\Shortcuts"
                    Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <FeatureRef Id="ProductFeature">
            <!-- Step 3: Tell WiX to install the shortcut and types -->
            <ComponentRef Id="RegisterTypes" />
            <ComponentRef Id="ApplicationShortcuts" />
            <ComponentRef Id="ApplicationDesktopShortcut" />
        </FeatureRef>

        <!-- Something from CMake-->
        <?include "product_fragment.wxi"?>
    </Product>
</Wix>
